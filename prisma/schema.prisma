// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Job {
  id              String   @id @default(uuid())
  title           String
  company         String
  location        String
  status          String   @default("In Progress") // Selected, Rejected, Withdrawn, In Progress
  jobDescription  String?
  matchScore      Int?
  applyLink       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Profile {
  id      String @id @default("user-profile")
  resume  String
}
